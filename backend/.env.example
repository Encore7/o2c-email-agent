APP_NAME="O2C Email Agent API"
API_V1_PREFIX="/api/v1"
LOG_LEVEL="INFO"
POSTGRES_DSN="postgresql://o2c:o2c@postgres:5432/o2c"

LLM_ENABLED=true
LLM_PROVIDER="ollama"
LLM_MODEL="llama3.1:latest"
LLM_FALLBACK_PROVIDER="ollama"
LLM_FALLBACK_MODEL="llama3.1:latest"
LLM_TEMPERATURE=0.0
OLLAMA_BASE_URL="http://host.docker.internal:11434"

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="O2C-Email-Agent"

GROQ_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""

GMAIL_ENABLED=true
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""
GMAIL_USER_ID="me"

METRICS_ENABLED=true
OTEL_ENABLED=false
OTEL_SERVICE_NAME="o2c-backend"
OTEL_ENVIRONMENT="local"
OTEL_EXPORTER_OTLP_ENDPOINT="alloy:4317"
OTEL_EXPORTER_INSECURE=true
